import java.util.Scanner;

public class Ex1 {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        int x;
        int fatorial = 1;

        System.out.print("Digite um numero: ");
        x = sc.nextInt();

        for(int i = 1; i <= x; i++){
            fatorial = fatorial * i;
        }

        System.out.println("Fatorial de " + x + " = " + fatorial);

    }
}